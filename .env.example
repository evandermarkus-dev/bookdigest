# ── Supabase ──────────────────────────────────────────────────────────────────
# From: supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# From: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ────────────────────────────────────────────────────────────
# From: resend.com → API Keys. Leave blank to disable emails in dev.
RESEND_API_KEY=re_...
EMAIL_FROM=BookDigest <noreply@yourdomain.com>

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used in email links. Set to your production domain in Vercel env vars.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# ── OpenAI (TTS for AI audio narration — Reader/Pro feature) ──────────────────
# From: platform.openai.com → API keys
OPENAI_API_KEY=sk-...

# ── Stripe ────────────────────────────────────────────────────────────────────
# From: dashboard.stripe.com → Developers → API keys
# Use sk_test_... / pk_test_... for development, sk_live_... / pk_live_... for production.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs for each plan (from Stripe dashboard → Products)
STRIPE_READER_PRICE_ID=price_...   # Reader plan (USD/month)
STRIPE_PRO_PRICE_ID=price_...      # Pro plan (USD/month)

# Webhook secret — run `stripe listen --forward-to localhost:3001/api/stripe/webhook`
# and copy the whsec_... value shown. Set to the dashboard secret in production.
STRIPE_WEBHOOK_SECRET=whsec_...
